{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Fallow JSON Output Schemas",
  "description": "Schemas for the JSON output of fallow commands: `fallow check --format json`, `fallow health --format json`, and `fallow dupes --format json`. Each command produces a distinct top-level structure sharing the metadata envelope (schema_version, version, elapsed_ms).",

  "oneOf": [
    { "$ref": "#/definitions/CheckOutput" },
    { "$ref": "#/definitions/HealthOutput" },
    { "$ref": "#/definitions/DupesOutput" }
  ],

  "definitions": {

    "CheckOutput": {
      "title": "fallow check --format json",
      "type": "object",
      "required": ["schema_version", "version", "elapsed_ms", "total_issues", "unused_files", "unused_exports", "unused_types", "unused_dependencies", "unused_dev_dependencies", "unused_optional_dependencies", "unused_enum_members", "unused_class_members", "unresolved_imports", "unlisted_dependencies", "duplicate_exports", "type_only_dependencies", "circular_dependencies"],
      "properties": {
        "schema_version": { "$ref": "#/definitions/SchemaVersion" },
        "version": { "$ref": "#/definitions/ToolVersion" },
        "elapsed_ms": { "$ref": "#/definitions/ElapsedMs" },
        "total_issues": {
          "type": "integer",
          "description": "Total number of issues found across all categories."
        },
        "unused_files": {
          "type": "array",
          "items": { "$ref": "#/definitions/UnusedFile" }
        },
        "unused_exports": {
          "type": "array",
          "items": { "$ref": "#/definitions/UnusedExport" }
        },
        "unused_types": {
          "type": "array",
          "items": { "$ref": "#/definitions/UnusedExport" }
        },
        "unused_dependencies": {
          "type": "array",
          "items": { "$ref": "#/definitions/UnusedDependency" }
        },
        "unused_dev_dependencies": {
          "type": "array",
          "items": { "$ref": "#/definitions/UnusedDependency" }
        },
        "unused_optional_dependencies": {
          "type": "array",
          "items": { "$ref": "#/definitions/UnusedDependency" }
        },
        "unused_enum_members": {
          "type": "array",
          "items": { "$ref": "#/definitions/UnusedMember" }
        },
        "unused_class_members": {
          "type": "array",
          "items": { "$ref": "#/definitions/UnusedMember" }
        },
        "unresolved_imports": {
          "type": "array",
          "items": { "$ref": "#/definitions/UnresolvedImport" }
        },
        "unlisted_dependencies": {
          "type": "array",
          "items": { "$ref": "#/definitions/UnlistedDependency" }
        },
        "duplicate_exports": {
          "type": "array",
          "items": { "$ref": "#/definitions/DuplicateExport" }
        },
        "type_only_dependencies": {
          "type": "array",
          "items": { "$ref": "#/definitions/TypeOnlyDependency" }
        },
        "circular_dependencies": {
          "type": "array",
          "items": { "$ref": "#/definitions/CircularDependency" }
        }
      }
    },

    "HealthOutput": {
      "title": "fallow health --format json",
      "type": "object",
      "required": ["schema_version", "version", "elapsed_ms", "summary", "findings"],
      "properties": {
        "schema_version": { "$ref": "#/definitions/SchemaVersion" },
        "version": { "$ref": "#/definitions/ToolVersion" },
        "elapsed_ms": { "$ref": "#/definitions/ElapsedMs" },
        "summary": { "$ref": "#/definitions/HealthSummary" },
        "findings": {
          "type": "array",
          "description": "Functions exceeding complexity thresholds, sorted by the --sort criteria.",
          "items": { "$ref": "#/definitions/HealthFinding" }
        },
        "file_scores": {
          "type": "array",
          "description": "Per-file health scores. Only present when --file-scores is used. Sorted by maintainability_index ascending (worst first). Zero-function files (barrels) are excluded by default.",
          "items": { "$ref": "#/definitions/FileHealthScore" }
        },
        "hotspots": {
          "type": "array",
          "description": "Hotspot entries combining git churn with complexity. Only present when --hotspots is used. Sorted by score descending (highest risk first).",
          "items": { "$ref": "#/definitions/HotspotEntry" }
        },
        "hotspot_summary": {
          "$ref": "#/definitions/HotspotSummary",
          "description": "Hotspot analysis summary. Only present when --hotspots is used."
        }
      }
    },

    "DupesOutput": {
      "title": "fallow dupes --format json",
      "description": "Duplication analysis output. Structure: clone_groups, clone_families, stats.",
      "type": "object",
      "required": ["schema_version", "version", "elapsed_ms"],
      "properties": {
        "schema_version": { "$ref": "#/definitions/SchemaVersion" },
        "version": { "$ref": "#/definitions/ToolVersion" },
        "elapsed_ms": { "$ref": "#/definitions/ElapsedMs" }
      }
    },

    "SchemaVersion": {
      "type": "integer",
      "description": "Schema version for this output format (independent of tool version). Adding new fields does not bump the version. Consumers should check this field to detect structural changes.",
      "examples": [3]
    },
    "ToolVersion": {
      "type": "string",
      "description": "Fallow tool version that produced this output.",
      "examples": ["1.6.0"]
    },
    "ElapsedMs": {
      "type": "integer",
      "description": "Analysis duration in milliseconds."
    },

    "HealthSummary": {
      "type": "object",
      "required": ["files_analyzed", "functions_analyzed", "functions_above_threshold", "max_cyclomatic_threshold", "max_cognitive_threshold"],
      "properties": {
        "files_analyzed": {
          "type": "integer",
          "description": "Number of files analyzed for complexity."
        },
        "functions_analyzed": {
          "type": "integer",
          "description": "Total number of functions found."
        },
        "functions_above_threshold": {
          "type": "integer",
          "description": "Number of functions exceeding at least one threshold (before --top truncation)."
        },
        "max_cyclomatic_threshold": {
          "type": "integer",
          "description": "Configured cyclomatic complexity threshold."
        },
        "max_cognitive_threshold": {
          "type": "integer",
          "description": "Configured cognitive complexity threshold."
        },
        "files_scored": {
          "type": "integer",
          "description": "Number of files with health scores. Only present when --file-scores is used. 0 indicates the flag was set but scoring failed."
        },
        "average_maintainability": {
          "type": "number",
          "description": "Average maintainability index across all scored files (before --top truncation). Only present when --file-scores is used and at least one file was scored.",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "HealthFinding": {
      "type": "object",
      "required": ["path", "name", "line", "col", "cyclomatic", "cognitive", "line_count", "exceeded"],
      "properties": {
        "path": {
          "type": "string",
          "description": "File path (relative to project root)."
        },
        "name": {
          "type": "string",
          "description": "Function name, or \"<anonymous>\" for unnamed functions/arrows."
        },
        "line": {
          "type": "integer",
          "description": "1-based line number."
        },
        "col": {
          "type": "integer",
          "description": "0-based byte column offset."
        },
        "cyclomatic": {
          "type": "integer",
          "description": "McCabe cyclomatic complexity (1 + decision points)."
        },
        "cognitive": {
          "type": "integer",
          "description": "SonarSource cognitive complexity (structural + nesting penalty)."
        },
        "line_count": {
          "type": "integer",
          "description": "Number of lines in the function body."
        },
        "exceeded": {
          "type": "string",
          "enum": ["cyclomatic", "cognitive", "both"],
          "description": "Which threshold(s) this function exceeds."
        }
      }
    },
    "FileHealthScore": {
      "type": "object",
      "required": ["path", "fan_in", "fan_out", "dead_code_ratio", "complexity_density", "maintainability_index", "total_cyclomatic", "total_cognitive", "function_count", "lines"],
      "description": "Per-file health score. Formula: MI = 100 - (complexity_density × 30) - (dead_code_ratio × 20) - min(ln(fan_out+1) × 4, 15), clamped to [0, 100]. Type-only exports excluded from dead_code_ratio.",
      "properties": {
        "path": {
          "type": "string",
          "description": "File path (relative to project root)."
        },
        "fan_in": {
          "type": "integer",
          "description": "Number of files that import this file."
        },
        "fan_out": {
          "type": "integer",
          "description": "Number of files this file directly imports."
        },
        "dead_code_ratio": {
          "type": "number",
          "description": "Fraction of value exports (excluding type-only) with zero references (0.0–1.0).",
          "minimum": 0,
          "maximum": 1
        },
        "complexity_density": {
          "type": "number",
          "description": "Total cyclomatic complexity / lines of code.",
          "minimum": 0
        },
        "maintainability_index": {
          "type": "number",
          "description": "Weighted composite score (0–100, higher is better).",
          "minimum": 0,
          "maximum": 100
        },
        "total_cyclomatic": {
          "type": "integer",
          "description": "Sum of cyclomatic complexity across all functions in this file."
        },
        "total_cognitive": {
          "type": "integer",
          "description": "Sum of cognitive complexity across all functions in this file."
        },
        "function_count": {
          "type": "integer",
          "description": "Number of functions in this file."
        },
        "lines": {
          "type": "integer",
          "description": "Total lines of code in the file."
        }
      }
    },

    "HotspotEntry": {
      "type": "object",
      "required": ["path", "score", "commits", "weighted_commits", "lines_added", "lines_deleted", "complexity_density", "fan_in", "trend"],
      "description": "A hotspot: a file that is both complex and frequently changing. Score = normalized_churn × normalized_complexity × 100 (0–100, higher = riskier).",
      "properties": {
        "path": {
          "type": "string",
          "description": "File path (relative to project root)."
        },
        "score": {
          "type": "number",
          "description": "Hotspot score (0–100). Higher means more risk.",
          "minimum": 0,
          "maximum": 100
        },
        "commits": {
          "type": "integer",
          "description": "Number of commits touching this file in the analysis window."
        },
        "weighted_commits": {
          "type": "number",
          "description": "Recency-weighted commit count (exponential decay, half-life 90 days)."
        },
        "lines_added": {
          "type": "integer",
          "description": "Total lines added across all commits in the window."
        },
        "lines_deleted": {
          "type": "integer",
          "description": "Total lines deleted across all commits in the window."
        },
        "complexity_density": {
          "type": "number",
          "description": "Total cyclomatic complexity / lines of code."
        },
        "fan_in": {
          "type": "integer",
          "description": "Number of files that import this file (blast radius)."
        },
        "trend": {
          "type": "string",
          "enum": ["accelerating", "stable", "cooling"],
          "description": "Churn trend: accelerating (recent > 1.5× older), stable, or cooling (recent < 0.67× older)."
        }
      }
    },
    "HotspotSummary": {
      "type": "object",
      "required": ["since", "min_commits", "files_analyzed", "files_excluded", "shallow_clone"],
      "properties": {
        "since": {
          "type": "string",
          "description": "Analysis window display string (e.g., '6 months')."
        },
        "min_commits": {
          "type": "integer",
          "description": "Minimum commits threshold."
        },
        "files_analyzed": {
          "type": "integer",
          "description": "Number of files with churn data meeting the threshold."
        },
        "files_excluded": {
          "type": "integer",
          "description": "Number of files excluded (below min_commits)."
        },
        "shallow_clone": {
          "type": "boolean",
          "description": "Whether the repository is a shallow clone."
        }
      }
    },

    "UnusedFile": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "description": "File path (forward slashes, relative to project root)."
        }
      }
    },
    "UnusedExport": {
      "type": "object",
      "required": ["path", "export_name", "is_type_only", "line", "col", "span_start", "is_re_export"],
      "properties": {
        "path": {
          "type": "string",
          "description": "File path containing the unused export."
        },
        "export_name": {
          "type": "string",
          "description": "Name of the unused export."
        },
        "is_type_only": {
          "type": "boolean",
          "description": "Whether this is a type-only export (interface, type alias)."
        },
        "line": {
          "type": "integer",
          "description": "1-based line number."
        },
        "col": {
          "type": "integer",
          "description": "0-based byte column offset."
        },
        "span_start": {
          "type": "integer",
          "description": "Byte offset into the source file (used by the fix command)."
        },
        "is_re_export": {
          "type": "boolean",
          "description": "Whether this finding comes from a barrel/index re-export rather than the source definition."
        }
      }
    },
    "UnusedDependency": {
      "type": "object",
      "required": ["package_name", "location", "path", "line"],
      "properties": {
        "package_name": {
          "type": "string",
          "description": "npm package name."
        },
        "location": {
          "type": "string",
          "enum": ["dependencies", "devDependencies"],
          "description": "Which section of package.json the dependency is listed in."
        },
        "path": {
          "type": "string",
          "description": "Path to the package.json where this dependency is listed."
        },
        "line": {
          "type": "integer",
          "description": "1-based line number of the dependency entry in package.json."
        }
      }
    },
    "UnusedMember": {
      "type": "object",
      "required": ["path", "parent_name", "member_name", "kind", "line", "col"],
      "properties": {
        "path": {
          "type": "string",
          "description": "File path containing the unused member."
        },
        "parent_name": {
          "type": "string",
          "description": "Name of the parent enum or class."
        },
        "member_name": {
          "type": "string",
          "description": "Name of the unused member."
        },
        "kind": {
          "type": "string",
          "description": "Member kind (e.g., EnumMember, ClassMethod, ClassProperty)."
        },
        "line": {
          "type": "integer",
          "description": "1-based line number."
        },
        "col": {
          "type": "integer",
          "description": "0-based byte column offset."
        }
      }
    },
    "UnresolvedImport": {
      "type": "object",
      "required": ["path", "specifier", "line", "col"],
      "properties": {
        "path": {
          "type": "string",
          "description": "File path containing the unresolved import."
        },
        "specifier": {
          "type": "string",
          "description": "The import specifier that could not be resolved."
        },
        "line": {
          "type": "integer",
          "description": "1-based line number."
        },
        "col": {
          "type": "integer",
          "description": "0-based byte column offset."
        }
      }
    },
    "UnlistedDependency": {
      "type": "object",
      "required": ["package_name", "imported_from"],
      "properties": {
        "package_name": {
          "type": "string",
          "description": "npm package name that is imported but not listed in package.json."
        },
        "imported_from": {
          "type": "array",
          "items": { "$ref": "#/definitions/ImportSite" },
          "description": "Import sites where this unlisted dependency is used."
        }
      }
    },
    "ImportSite": {
      "type": "object",
      "required": ["path", "line", "col"],
      "properties": {
        "path": {
          "type": "string",
          "description": "File containing the import."
        },
        "line": {
          "type": "integer",
          "description": "1-based line number."
        },
        "col": {
          "type": "integer",
          "description": "0-based byte column offset."
        }
      }
    },
    "DuplicateExport": {
      "type": "object",
      "required": ["export_name", "locations"],
      "properties": {
        "export_name": {
          "type": "string",
          "description": "The export name that appears in multiple modules."
        },
        "locations": {
          "type": "array",
          "items": { "$ref": "#/definitions/DuplicateLocation" },
          "description": "Locations where this export name is defined."
        }
      }
    },
    "DuplicateLocation": {
      "type": "object",
      "required": ["path", "line", "col"],
      "properties": {
        "path": {
          "type": "string",
          "description": "File containing the duplicate export."
        },
        "line": {
          "type": "integer",
          "description": "1-based line number."
        },
        "col": {
          "type": "integer",
          "description": "0-based byte column offset."
        }
      }
    },
    "TypeOnlyDependency": {
      "type": "object",
      "required": ["package_name", "path", "line"],
      "properties": {
        "package_name": {
          "type": "string",
          "description": "Production dependency that is only used via type-only imports."
        },
        "path": {
          "type": "string",
          "description": "Path to the package.json where this dependency is listed."
        },
        "line": {
          "type": "integer",
          "description": "1-based line number of the dependency entry in package.json."
        }
      }
    },
    "CircularDependency": {
      "type": "object",
      "required": ["files", "length", "line", "col"],
      "properties": {
        "files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "File paths forming the import cycle, in cycle order."
        },
        "length": {
          "type": "integer",
          "description": "Number of files in the cycle."
        },
        "line": {
          "type": "integer",
          "description": "1-based line number of the import that starts the cycle."
        },
        "col": {
          "type": "integer",
          "description": "0-based byte column offset of the import that starts the cycle."
        }
      }
    }
  }
}
