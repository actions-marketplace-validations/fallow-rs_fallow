{
  "name": "fallow",
  "version": "1.0.2",
  "description": "Find unused files, exports, and dependencies in JavaScript/TypeScript projects",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fallow-rs/fallow.git"
  },
  "homepage": "https://docs.fallow.tools",
  "bugs": {
    "url": "https://github.com/fallow-rs/fallow/issues"
  },
  "keywords": [
    "dead-code",
    "unused",
    "exports",
    "dependencies",
    "lint",
    "analyzer",
    "typescript",
    "javascript"
  ],
  "engines": {
    "node": ">=16"
  },
  "bin": {
    "fallow": "bin/fallow"
  },
  "files": [
    "bin",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "detect-libc": "^2.0.0"
  },
  "optionalDependencies": {
    "@fallow-cli/darwin-arm64": "1.0.2",
    "@fallow-cli/darwin-x64": "1.0.2",
    "@fallow-cli/linux-x64-gnu": "1.0.2",
    "@fallow-cli/linux-arm64-gnu": "1.0.2",
    "@fallow-cli/linux-x64-musl": "1.0.2",
    "@fallow-cli/linux-arm64-musl": "1.0.2",
    "@fallow-cli/win32-x64-msvc": "1.0.2"
  }
}
